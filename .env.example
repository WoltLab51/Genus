# GENUS — Umgebungsvariablen-Vorlage
# Kopiere diese Datei nach .env und fülle die Werte aus.
# Die .env-Datei ist in .gitignore eingetragen und wird NIEMALS ins Repo hochgeladen.
#
# Starten:
#   set -a && source .env && set +a
#   uvicorn genus.main:app --host 0.0.0.0 --port 8000
#
# Oder mit uvicorn direkt:
#   GENUS_API_KEY=dein-schluessel GENUS_MASTER_KEY=dein-master uvicorn genus.main:app

# ── Pflicht ──────────────────────────────────────────────────────────────────

# API-Schlüssel für Bearer-Authentifizierung (wird im Chat-Login eingegeben)
# Wähle einen langen, zufälligen String (mind. 32 Zeichen empfohlen)
GENUS_API_KEY=dein-geheimer-api-schluessel-hier

# Master-Schlüssel für Superadmin-Zugriff (Ronny)
# Getrennt vom API-Key — gibt Zugriff auf alle Identitätsfunktionen
GENUS_MASTER_KEY=dein-geheimer-master-schluessel-hier

# ── LLM-Provider ─────────────────────────────────────────────────────────────

# Ollama (lokal auf dem Pi — Standard)
GENUS_LLM_OLLAMA_URL=http://localhost:11434
GENUS_LLM_OLLAMA_MODEL=llama3.2

# OpenAI (optional — nur setzen wenn gewünscht)
# GENUS_OPENAI_API_KEY=sk-...

# LLM-Routing-Strategie: adaptive | quality | cost | local
GENUS_LLM_STRATEGY=adaptive

# ── Rollen-Schlüssel (optional — erweitert den einfachen api_key-Modus) ─────

# Wenn nur GENUS_API_KEY gesetzt ist, hat dieser Key Admin-Rechte (einfachster Modus)
# Für Mehrbenutzer-Setup können separate Keys pro Rolle gesetzt werden:
# GENUS_ADMIN_KEY=admin-schluessel
# GENUS_OPERATOR_KEY=operator-schluessel
# GENUS_READER_KEY=leser-schluessel

# ── Datenpfade (optional — Standard-Werte funktionieren für die meisten Fälle) ─

# GENUS_CONVERSATIONS_DIR=var/conversations
# GENUS_PROFILES_DIR=var/profiles
# GENUS_GROUPS_DIR=var/groups
# GENUS_VAULT_DIR=var/vault
# GENUS_EPISODES_DIR=var/episodes
# GENUS_FACTS_DIR=var/facts
# GENUS_MONOLOGUE_DIR=var/inner_monologue
# GENUS_NEEDS_DIR=var/needs
# GENUS_LLM_SCORES_PATH=var/router_scores.jsonl

# ── Identität / Gruppen ───────────────────────────────────────────────────────

# Standardname der Familie-Gruppe beim ersten Start (Standard: "Meine Familie")
# GENUS_DEFAULT_GROUP_NAME=Meine Familie

# ── Verschlüsselung ───────────────────────────────────────────────────────────

# Fernet-Schlüssel für CredentialStore (Fernet.generate_key().decode())
# Wenn nicht gesetzt, wird ein Schlüssel automatisch generiert und lokal gespeichert.
# GENUS_CREDENTIAL_KEY=...

# ── Redis (optional — nur für Multi-Device / verteilten Betrieb) ──────────────

# Redis-Verbindungs-URL für RedisMessageBus (Standard: redis://localhost:6379/0)
# Nur erforderlich wenn GENUS mit Redis-Transport betrieben wird.
# GENUS_REDIS_URL=redis://localhost:6379/0

# ── Session-Einstellungen ─────────────────────────────────────────────────────

# GENUS_SESSION_TIMEOUT_MINUTES=30
# GENUS_MAX_CONVERSATION_HISTORY=20

# ── Sandbox ───────────────────────────────────────────────────────────────────

# GENUS_SANDBOX_ENABLED=true

# ── Server (optional; nicht direkt von GENUS oder uvicorn aus .env gelesen) ───

# Diese Variablen sind nur für externe Wrapper/Process-Manager gedacht, die sie
# auf `uvicorn --host ... --port ...` abbilden. Standard-uvicorn liest HOST
# und PORT nicht automatisch aus der Umgebung.
# HOST=0.0.0.0
# PORT=8000
